{
  "name": "@workspace/ui-components",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "rules": "vitest run -c vitest.config.ts"
  },
  "dependencies": {
    "date-fns": "catalog:",
    "@workspace/ui-core": "workspace:*",
    "@workspace/ui-theme": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles/index.css",
    "./stable/*": "./src/components/stable/*/index.ts",
    "./labs/*": "./src/components/labs/*/index.ts"
  }
