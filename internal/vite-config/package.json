{
  "name": "@workspace/vite-config",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "exports": {
    "./react-app": {
      "types": "./src/react-app/index.ts",
      "default": "./dist/react-app/index.js"
    },
    "./showcase": {
      "types": "./src/showcase/index.ts",
      "default": "./dist/showcase/index.js"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
